# CityPulse Backend Environment Config Pattern

# Server Port
PORT=5000

# Security (Replace with random long string in production)
JWT_SECRET=super_secret_dev_key_123

# Allow CORS requests securely from frontend domain
FRONTEND_URL=http://localhost:5173

# TELEMETRY API KEYS 
# (Leave as YOUR_API_KEY_HERE to utilize the built-in Mock Data Fallback engine gracefully)
OPENWEATHER_API_KEY=YOUR_API_KEY_HERE
NEWS_API_KEY=YOUR_API_KEY_HERE
